# ---------------------------------------------------------------------------
# compose — read .brainbrew.yml and generate output in the specified format
# ---------------------------------------------------------------------------
cmd_compose() {
    local format="agents"
    local all=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --format)
                shift
                format="${1:-}"
                [ -z "$format" ] && error "Usage: brainbrew compose --format <agents|copilot|cursor|windsurf|claude>"
                ;;
            --all) all=true ;;
            *)     error "Unknown option: $1" ;;
        esac
        shift
    done

    collect_modules

    if $all; then
        write_format_agents
        write_format_copilot
        write_format_cursor
        write_format_windsurf
        write_format_claude
        return
    fi

    case "$format" in
        agents)   write_format_agents ;;
        copilot)  write_format_copilot ;;
        cursor)   write_format_cursor ;;
        windsurf) write_format_windsurf ;;
        claude)   write_format_claude ;;
        *)        error "Unknown format: $format. Use: agents, copilot, cursor, windsurf, claude" ;;
    esac
}

# ---------------------------------------------------------------------------
# _sync_repo — fetch .md files from a single GitHub repo into local cache
# ---------------------------------------------------------------------------
_sync_repo() {
    local repo="$1" branch="$2" rpath="$3" token="$4" dry_run="$5"
    local cache_dir="$REPOS_DIR/$repo"
    local tmp_tree="/tmp/brainbrew_tree_$$.json"
    local tmp_files="/tmp/brainbrew_files_$$.txt"

    info "Fetching $repo (branch: $branch, path: ${rpath:-/})..."

    local tree_url="https://api.github.com/repos/$repo/git/trees/$branch?recursive=1"
    local http_code

    if [ -n "$token" ]; then
        http_code=$(curl -s -o "$tmp_tree" -w "%{http_code}" \
            -H "Authorization: Bearer $token" \
            -H "Accept: application/vnd.github+json" \
            "$tree_url")
    else
        http_code=$(curl -s -o "$tmp_tree" -w "%{http_code}" \
            -H "Accept: application/vnd.github+json" \
            "$tree_url")
    fi

    if [ "$http_code" != "200" ]; then
        if [ "$http_code" = "401" ] || [ "$http_code" = "403" ]; then
            warn "$repo: HTTP $http_code — export GITHUB_TOKEN for private repos."
        else
            warn "$repo: HTTP $http_code — skipping."
        fi
        rm -f "$tmp_tree"
        return 0
    fi

    python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
prefix = sys.argv[2].strip('/')
if prefix:
    prefix += '/'
for item in data.get('tree', []):
    if item['type'] != 'blob' or not item['path'].endswith('.md'):
        continue
    fp = item['path']
    if prefix and not fp.startswith(prefix):
        continue
    rel = fp[len(prefix):] if prefix else fp
    print(f'{fp}|{rel}')
" "$tmp_tree" "$rpath" > "$tmp_files" 2>/dev/null

    rm -f "$tmp_tree"

    local file_count
    file_count=$(wc -l < "$tmp_files" | tr -d ' ')

    if [ "$file_count" -eq 0 ]; then
        warn "$repo: no .md files found${rpath:+ under $rpath}."
        rm -f "$tmp_files"
        return 0
    fi

    if $dry_run; then
        info "Would sync $file_count file(s) from $repo:"
        while IFS='|' read -r _ rel; do
            echo "    ${rel%.md}"
        done < "$tmp_files"
        rm -f "$tmp_files"
        return 0
    fi

    mkdir -p "$cache_dir"

    local synced=0
    while IFS='|' read -r full_path rel_path; do
        local target="$cache_dir/$rel_path"
        mkdir -p "$(dirname "$target")"
        local raw_url="https://raw.githubusercontent.com/$repo/$branch/$full_path"
        local ok=false

        if [ -n "$token" ]; then
            curl -s -f -H "Authorization: Bearer $token" -o "$target" "$raw_url" 2>/dev/null && ok=true
        else
            curl -s -f -o "$target" "$raw_url" 2>/dev/null && ok=true
        fi

        if $ok; then
            echo "    synced: ${rel_path%.md}"
            synced=$((synced + 1))
        else
            warn "  failed: $full_path"
        fi
    done < "$tmp_files"

    if [ -d "$cache_dir" ]; then
        local tmp_expected="/tmp/brainbrew_expected_$$.txt"
        cut -d'|' -f2 "$tmp_files" | sort > "$tmp_expected"
        while IFS= read -r cached_file; do
            local rel_cached="${cached_file#$cache_dir/}"
            if ! grep -qxF "$rel_cached" "$tmp_expected" 2>/dev/null; then
                rm -f "$cached_file"
                info "  removed orphan: ${rel_cached%.md}"
            fi
        done < <(find "$cache_dir" -name "*.md" -type f 2>/dev/null)
        find "$cache_dir" -type d -empty -delete 2>/dev/null || true
        rm -f "$tmp_expected"
    fi

    rm -f "$tmp_files"
    success "Synced $synced file(s) from $repo"
}

# ---------------------------------------------------------------------------
# sync-repos — fetch .md files from configured GitHub repos
# ---------------------------------------------------------------------------
cmd_sync_repos() {
    local dry_run=false
    [ "${1:-}" = "--dry-run" ] && dry_run=true

    [ -f "$CONFIG_FILE" ] || error "No $CONFIG_FILE found. Run 'brainbrew init' first."

    local token
    token=$(get_github_token)

    local repos=""
    repos=$(parse_repos_config "$CONFIG_FILE")

    if [ -z "$repos" ]; then
        warn "No repos configured in $CONFIG_FILE."
        return
    fi

    while IFS='|' read -r repo branch rpath; do
        [ -z "$repo" ] && continue
        _sync_repo "$repo" "$branch" "$rpath" "$token" "$dry_run"
    done <<< "$repos"
}

# ---------------------------------------------------------------------------
# global — install Cursor rules & skills to ~/.cursor/
# ---------------------------------------------------------------------------
cmd_global() {
    info "Installing global Cursor configuration..."

    if [ -d "$BRAINBREW_DIR/cursor/rules" ]; then
        mkdir -p "$HOME/.cursor/rules"
        for file in "$BRAINBREW_DIR/cursor/rules/"*.mdc; do
            [ -f "$file" ] || continue
            local name
            name=$(basename "$file")
            ln -sf "$file" "$HOME/.cursor/rules/$name"
            success "Linked rule: $name"
        done
    fi

    if [ -d "$BRAINBREW_DIR/cursor/skills" ]; then
        mkdir -p "$HOME/.cursor/skills"
        for dir in "$BRAINBREW_DIR/cursor/skills/"*/; do
            [ -d "$dir" ] || continue
            local name
            name=$(basename "$dir")
            ln -sf "$dir" "$HOME/.cursor/skills/$name"
            success "Linked skill: $name"
        done
    fi

    success "Global configuration installed!"
}

# ---------------------------------------------------------------------------
# link — symlink brainbrew to /usr/local/bin
# ---------------------------------------------------------------------------
cmd_link() {
    local target="/usr/local/bin/brainbrew"

    if [ -L "$target" ] || [ -f "$target" ]; then
        warn "$target already exists."
        read -rp "Overwrite? [y/N] " reply
        [[ ! "$reply" =~ ^[Yy]$ ]] && exit 0
    fi

    ln -sf "$BRAINBREW_DIR/brainbrew" "$target"
    success "brainbrew linked to $target"
    info "You can now run 'brainbrew' from anywhere."
}

# ---------------------------------------------------------------------------
# status — show current project configuration
# ---------------------------------------------------------------------------
cmd_status() {
    if [ ! -f "$CONFIG_FILE" ]; then
        warn "No $CONFIG_FILE found in this directory."
        return
    fi

    local repo_configs=""
    repo_configs=$(parse_repos_config "$CONFIG_FILE")

    if [ -n "$repo_configs" ]; then
        echo ""
        echo -e "${BOLD}GitHub repos:${NC}"
        echo ""
        while IFS='|' read -r repo branch rpath; do
            [ -z "$repo" ] && continue
            local cache_dir="$REPOS_DIR/$repo"
            local count=0
            [ -d "$cache_dir" ] && count=$(find "$cache_dir" -name "*.md" -type f 2>/dev/null | wc -l | tr -d ' ')
            echo -e "  ${GREEN}$repo${NC} (branch: $branch, path: ${rpath:-/}) ${DIM}[$count cached]${NC}"
        done <<< "$repo_configs"
    fi

    echo ""
    echo -e "${BOLD}Current modules:${NC}"
    echo ""

    local in_modules=false
    while IFS= read -r line; do
        if [[ "$line" == "modules:" ]]; then
            in_modules=true
            continue
        fi
        if $in_modules; then
            if [[ "$line" =~ ^[[:space:]]*-[[:space:]]+(.*) ]]; then
                local module="${BASH_REMATCH[1]}"
                local resolved
                if resolved=$(resolve_module "$module"); then
                    local source
                    source=$(module_source_label "$resolved")
                    echo -e "  ${GREEN}✓${NC} $module ${DIM}($source)${NC}"
                else
                    echo -e "  ${RED}✗${NC} $module (not found — run 'brainbrew sync-repos')"
                fi
            elif [[ ! "$line" =~ ^[[:space:]]*$ && ! "$line" =~ ^[[:space:]]*# ]]; then
                in_modules=false
            fi
        fi
    done < "$CONFIG_FILE"

    echo ""

    if [ -f "$OUTPUT_FILE" ]; then
        local size
        size=$(wc -c < "$OUTPUT_FILE" | tr -d ' ')
        info "$OUTPUT_FILE exists (${size} bytes)"
    else
        warn "$OUTPUT_FILE not generated yet. Run 'brainbrew compose'."
    fi

    echo ""
}

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------
usage() {
    cat << EOF

${BOLD}brainbrew${NC} — Compose AI context from GitHub module repos

${YELLOW}Usage:${NC}
  brainbrew <command> [args]

${YELLOW}Commands:${NC}
  init                Initialize project (configure repo, pick modules)
  update [repo]       Add default or custom repos to existing project
  compose [options]   Compose context from .brainbrew.yml
  add <module>        Add a module to current project
  remove <module>     Remove a module from current project
  list                List available modules
  status              Show current project configuration
  sync-repos          Fetch modules from configured GitHub repos
  global              Install global Cursor rules & skills
  link                Add brainbrew to PATH (/usr/local/bin)

${YELLOW}Compose formats:${NC}
  compose                    AGENTS.md (default)
  compose --format copilot   .github/copilot-instructions.md
  compose --format cursor    .cursor/rules/brainbrew.mdc
  compose --format windsurf  .windsurfrules
  compose --format claude    CLAUDE.md
  compose --all              All formats at once

${YELLOW}Sync:${NC}
  sync-repos [--dry-run]  Fetch .md files from configured GitHub repos

${YELLOW}Update:${NC}
  update                     Interactive — offer defaults + ask for repo
  update --defaults          Add default BrainBrew modules repo
  update user/repo           Add a specific repo

${YELLOW}Examples:${NC}
  brainbrew init                     # Setup project (repo + modules)
  brainbrew update --defaults        # Add default modules to existing project
  brainbrew update user/ai-modules   # Add a custom repo
  brainbrew sync-repos               # Re-fetch latest modules
  brainbrew compose --all            # Generate for all AI tools
  brainbrew add coding/conventions   # Add a module

${YELLOW}Getting started:${NC}
  1. ${GREEN}brainbrew link${NC}                # Add to PATH
  2. ${GREEN}brainbrew init${NC}                 # Configure repo & pick modules
  3. ${GREEN}brainbrew compose --all${NC}        # Generate for all AI tools

EOF
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
    init)       cmd_init ;;
    update)     shift; cmd_update "${1:-}" ;;
    compose)    shift; cmd_compose "$@" ;;
    add)        shift; cmd_add "${1:-}" ;;
    remove)     shift; cmd_remove "${1:-}" ;;
    list)       cmd_list ;;
    status)     cmd_status ;;
    global)     cmd_global ;;
    link)       cmd_link ;;
    sync-repos) shift; cmd_sync_repos "${1:-}" ;;
    help|-h|--help) usage ;;
    *)          usage ;;
esac
